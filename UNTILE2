        "folium.Marker(center_pt, popup=\"Ben Thanh\", icon=folium.Icon(color=\"red\")).add_to(m)\n",
        "for name, pt in places:\n",
        "    folium.Marker(pt, popup=name).add_to(m)\n",
        "    folium.PolyLine([center_pt, pt], color=\"blue\").add_to(m)\n",
        "m"
